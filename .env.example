# Resume Agent Environment Variables
# Copy this file to .env and fill in your values

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Google Sheets
GOOGLE_CREDENTIALS_PATH=config/credentials.json
URL_SHEET_ID=your_url_sheet_id_here
TRACKER_SHEET_ID=your_tracker_sheet_id_here

# Model Configuration (change these to swap models)
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-sonnet-4-6
CHATGPT_MODEL=gpt-5.4-nano

# LaTeX Compiler
# Windows (MiKTeX): C:\Users\<you>\AppData\Local\Programs\MiKTeX\miktex\bin\x64\pdflatex.exe
# macOS/Linux (TeX Live): pdflatex
PDFLATEX_PATH=pdflatex
